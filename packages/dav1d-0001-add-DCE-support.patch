From: _ <>
Date: Wed, 14 Jan 2026 00:00:00 +0000
Subject: [PATCH] add DCE support

---
 src/arm/cpu.c            |  8 ++++----
 src/ext/x86/x86inc.asm   | 17 ++++++++++++++---
 src/x86/itx16_avx2.asm   |  2 ++
 src/x86/itx16_avx512.asm |  2 ++
 src/x86/itx16_sse.asm    |  2 ++
 src/x86/itx_avx2.asm     |  2 ++
 src/x86/itx_avx512.asm   |  2 ++
 src/x86/itx_sse.asm      |  2 ++
 src/x86/mc16_avx2.asm    |  2 ++
 src/x86/mc16_avx512.asm  |  2 ++
 src/x86/mc16_sse.asm     |  2 ++
 src/x86/mc_avx2.asm      |  2 ++
 src/x86/mc_avx512.asm    |  2 ++
 src/x86/mc_sse.asm       |  2 ++
 14 files changed, 42 insertions(+), 7 deletions(-)

diff --git a/src/arm/cpu.c b/src/arm/cpu.c
index c895049..7dce9f8 100644
--- a/src/arm/cpu.c
+++ b/src/arm/cpu.c
@@ -136,19 +136,19 @@ COLD unsigned dav1d_get_cpu_flags_arm(void) {
 
 COLD unsigned dav1d_get_cpu_flags_arm(void) {
     unsigned flags = dav1d_get_default_cpu_flags();
-#ifdef PF_ARM_V82_DP_INSTRUCTIONS_AVAILABLE
+#if defined(PF_ARM_V82_DP_INSTRUCTIONS_AVAILABLE) && !defined(__ARM_FEATURE_DOTPROD)
     if (IsProcessorFeaturePresent(PF_ARM_V82_DP_INSTRUCTIONS_AVAILABLE))
         flags |= DAV1D_ARM_CPU_FLAG_DOTPROD;
 #endif
-#ifdef PF_ARM_SVE_INSTRUCTIONS_AVAILABLE
+#if defined(PF_ARM_SVE_INSTRUCTIONS_AVAILABLE) && !defined(__ARM_FEATURE_SVE)
     if (IsProcessorFeaturePresent(PF_ARM_SVE_INSTRUCTIONS_AVAILABLE))
         flags |= DAV1D_ARM_CPU_FLAG_SVE;
 #endif
-#ifdef PF_ARM_SVE2_INSTRUCTIONS_AVAILABLE
+#if defined(PF_ARM_SVE2_INSTRUCTIONS_AVAILABLE) && !defined(__ARM_FEATURE_SVE2)
     if (IsProcessorFeaturePresent(PF_ARM_SVE2_INSTRUCTIONS_AVAILABLE))
         flags |= DAV1D_ARM_CPU_FLAG_SVE2;
 #endif
-#ifdef PF_ARM_V82_I8MM_INSTRUCTIONS_AVAILABLE
+#if defined(PF_ARM_V82_I8MM_INSTRUCTIONS_AVAILABLE) && !defined(__ARM_FEATURE_MATMUL_INT8)
     if (IsProcessorFeaturePresent(PF_ARM_V82_I8MM_INSTRUCTIONS_AVAILABLE))
         flags |= DAV1D_ARM_CPU_FLAG_I8MM;
 #endif
diff --git a/src/ext/x86/x86inc.asm b/src/ext/x86/x86inc.asm
index ece93f1..0398ad4 100644
--- a/src/ext/x86/x86inc.asm
+++ b/src/ext/x86/x86inc.asm
@@ -778,9 +778,9 @@ DECLARE_ARG 7, 8, 9, 10, 11, 12, 13, 14
 
 %define last_branch_adr $$
 %macro AUTO_REP_RET 0
-    %if notcpuflag(ssse3)
-        times ((last_branch_adr-$)>>31)+1 rep ; times 1 iff $ == last_branch_adr.
-    %endif
+    ;%if notcpuflag(ssse3)
+    ;    times ((last_branch_adr-$)>>31)+1 rep ; times 1 iff $ == last_branch_adr.
+    ;%endif
     ret
     annotate_function_size
 %endmacro
@@ -814,6 +814,10 @@ BRANCH_INSTR jz, je, jnz, jne, jl, jle, jnl, jnle, jg, jge, jng, jnge, ja, jae,
 ; arch-independent part
 ;=============================================================================
 
+%ifndef ENABLE_DCE
+    %define ENABLE_DCE 1
+%endif
+
 %assign function_align 16
 
 ; Begin a function.
@@ -843,12 +847,19 @@ BRANCH_INSTR jz, je, jnz, jne, jl, jle, jnl, jnle, jg, jge, jng, jnge, ja, jae,
     %xdefine current_function_section __SECT__
     %if FORMAT_ELF
         %if %1
+            %if ENABLE_DCE
+                section .text.%2 progbits alloc exec nowrite
+                %define last_branch_adr $$
+            %endif
             global %2:function hidden
         %else
             global %2:function
         %endif
     %elif FORMAT_MACHO && HAVE_PRIVATE_EXTERN && %1
         global %2:private_extern
+    %elif WIN64 && %1 && ENABLE_DCE
+        section .text$%2 comdat=1:%2
+        %define last_branch_adr $$
     %else
         global %2
     %endif
