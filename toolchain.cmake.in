SET(CMAKE_SYSTEM_NAME Windows)
SET(CMAKE_SYSTEM_PROCESSOR @TARGET_CPU_FAMILY@)
SET(CMAKE_TOOLCHAIN_PREFIX @TARGET_ARCH@)
SET(CMAKE_C_COMPILER @TARGET_ARCH@-clang)
SET(CMAKE_CXX_COMPILER @TARGET_ARCH@-clang++)
SET(CMAKE_ASM_COMPILER @TARGET_ARCH@-clang)
SET(CMAKE_RC_COMPILER @TARGET_ARCH@-windres)
SET(CMAKE_C_COMPILER_WORKS ON)
SET(CMAKE_CXX_COMPILER_WORKS ON)
SET(CMAKE_ASM_COMPILER_WORKS ON)
SET(CMAKE_RC_COMPILER_WORKS ON)
LIST(APPEND CMAKE_PROGRAM_PATH @CMAKE_INSTALL_PREFIX@/bin ...)
SET(CMAKE_FIND_ROOT_PATH @MINGW_INSTALL_PREFIX@)
SET(CMAKE_INSTALL_PREFIX @MINGW_INSTALL_PREFIX@)
SET(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
SET(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
SET(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
