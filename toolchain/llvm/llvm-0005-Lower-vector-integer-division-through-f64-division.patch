     { ISD::FDIV,    MVT::v4f64,   { 44, 45, 1, 3 } }, // SNB from http://www.agner.org/
+
+    { ISD::SDIV,    MVT::v4i32,   { 10 } },
+    { ISD::SREM,    MVT::v4i32,   { 10 } },
+    { ISD::UDIV,    MVT::v4i32,   { 10 } },
+    { ISD::UREM,    MVT::v4i32,   { 10 } },
+    { ISD::SDIV,    MVT::v2i32,   { 10 } },
+    { ISD::SREM,    MVT::v2i32,   { 10 } },
+    { ISD::UDIV,    MVT::v2i32,   { 10 } },
