+
+    { ISD::SDIV,    MVT::v8i16,   { 10 } },
+    { ISD::SREM,    MVT::v8i16,   { 10 } },
+    { ISD::UDIV,    MVT::v8i16,   { 10 } },
+    { ISD::UREM,    MVT::v8i16,   { 10 } },
+    { ISD::SDIV,    MVT::v4i16,   { 10 } },
+    { ISD::SREM,    MVT::v4i16,   { 10 } },
+    { ISD::UDIV,    MVT::v4i16,   { 10 } },
+    { ISD::UREM,    MVT::v4i16,   { 10 } },
+
+    { ISD::SDIV,    MVT::v8i8,    { 10 } },
+    { ISD::SREM,    MVT::v8i8,    { 10 } },
+    { ISD::UDIV,    MVT::v8i8,    { 10 } },
+    { ISD::UREM,    MVT::v8i8,    { 10 } },
+    { ISD::SDIV,    MVT::v4i8,    { 10 } },
+    { ISD::SREM,    MVT::v4i8,    { 10 } },
+    { ISD::UDIV,    MVT::v4i8,    { 10 } },
