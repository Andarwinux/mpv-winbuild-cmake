+    { ISD::UREM,    MVT::v8i32,   { 10 } },
+
+    { ISD::SDIV,    MVT::v16i16,  { 10 } },
+    { ISD::SREM,    MVT::v16i16,  { 10 } },
+    { ISD::UDIV,    MVT::v16i16,  { 10 } },
+    { ISD::UREM,    MVT::v16i16,  { 10 } },
+
+    { ISD::SDIV,    MVT::v16i8,   { 10 } },
+    { ISD::SREM,    MVT::v16i8,   { 10 } },
