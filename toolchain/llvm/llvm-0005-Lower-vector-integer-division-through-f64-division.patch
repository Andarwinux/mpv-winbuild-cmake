   if (ST->hasAVX512())
@@ -1319,6 +1339,33 @@ InstructionCost X86TTIImpl::getArithmeticInstrCost(
     { ISD::FDIV,    MVT::f64,     { 22, 22, 1, 1 } }, // SNB from http://www.agner.org/
